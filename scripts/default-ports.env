#!/bin/bash
# Eregen Platform - Default Port Configuration Reference
# Copy this file to the project root as .env and customize ports as needed.
# Do NOT edit this file — create your own .env instead.
# © 2026 Eregen (颐贞). All rights reserved.

# ============================================
# Cloud Backend Services
# ============================================
PORT_API_SERVER=8080
PORT_PUSH_SERVICE=8085
PORT_DATA_PIPELINE=8087
PORT_ADMIN_API=8089
# gateway is MQTT-only (no HTTP port); connects to EMQX at EMQX_MQTT_PORT

# ============================================
# B2B Services
# ============================================
PORT_HOSPITAL_API=8082
PORT_COMMUNITY_PLATFORM=8083
PORT_INSURANCE_INTEGRATION=8084

# ============================================
# Frontend Applications
# ============================================
PORT_ADMIN_WEB=3001
PORT_WEBSITE=1313
# family-app: Flutter debug — Chrome :5173 or device-specific
# miniprogram: WeChat DevTools — no command-line port

# ============================================
# Infrastructure (for reference when running native)
# ============================================
# These are typically managed via Docker compose.
# When running services natively, configure these ports accordingly.
PORT_POSTGRES=5432
PORT_REDIS=6379
PORT_INFLUXDB=8086
PORT_EMQX_MQTT=1883
PORT_EMQX_DASHBOARD=18083
PORT_NATS=4222
PORT_PROMETHEUS=9090
PORT_GRAFANA=3002
PORT_LOKI=3100
