# PostgreSQL
PG_USER=eregen
PG_PASSWORD=eregen_dev_password
PG_DATABASE=eregen

# InfluxDB
INFLUX_USER=eregen
INFLUX_PASSWORD=eregen_dev_password
INFLUX_TOKEN=eregen_admin_token

# EMQX
EMQX_USER=admin
EMQX_PASSWORD=eregen_dev_password

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=eregen_dev_password
