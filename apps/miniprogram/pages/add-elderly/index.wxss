.page {
  min-height: 100vh;
  background: #F9FAFB;
  padding: 0 40rpx;
}

.header {
  padding: 60rpx 0 40rpx;
  text-align: center;
}
.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #6B7280;
}

.form-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 36rpx;
}
.label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}
.required {
  color: #EF4444;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 30rpx;
  background: #F9FAFB;
  box-sizing: border-box;
}
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.placeholder {
  color: #9CA3AF;
}
.arrow {
  color: #9CA3AF;
  font-size: 20rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-top: 48rpx;
  text-align: center;
}
.submit-btn.loading {
  opacity: 0.7;
}
