<view class="page">
  <view class="header">
    <text class="title">添加老人信息</text>
    <text class="subtitle">为家人创建健康档案</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <view class="label">
        <text class="label-text">姓名</text>
        <text class="required">*</text>
      </view>
      <input
        class="input-field"
        placeholder="请输入老人姓名"
        maxlength="20"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item">
      <view class="label">
        <text class="label-text">出生日期</text>
        <text class="required">*</text>
      </view>
      <picker
        mode="date"
        fields="year"
        value="{{birthDate}}"
        start="1930-01-01"
        end="{{today}}"
        bindchange="onBirthDateChange"
      >
        <view class="input-field picker-display">
          <text wx:if="{{birthDate}}">{{birthDate}}</text>
          <text wx:else class="placeholder">请选择出生日期</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>

    <button
      class="submit-btn {{loading ? 'loading' : ''}}"
      bindtap="submit"
      disabled="{{loading}}"
    >
      <text wx:if="{{!loading}}">确认添加</text>
      <text wx:else>添加中...</text>
    </button>
  </view>
</view>
