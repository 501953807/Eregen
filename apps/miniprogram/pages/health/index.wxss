/* pages/health/index.wxss */
.container {
  min-height: 100vh;
  background: #F7F8FC;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F5;
}
.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 32rpx;
  height: 32rpx;
}
.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-right: 60rpx;
}
.header-share {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-icon {
  width: 32rpx;
  height: 32rpx;
}

.scroll-content {
  height: calc(100vh - 100rpx);
}

/* Risk Card */
.risk-card {
  margin: 20rpx 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 24rpx;
}
.risk-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}
.risk-gauge {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}
.gauge-canvas {
  margin-right: 16rpx;
}
.risk-score-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.risk-score {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}
.risk-max {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}
.risk-level {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 8rpx;
}
.risk-summary {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  line-height: 1.5;
}

/* Time Selector */
.time-selector {
  display: flex;
  padding: 0 24rpx 12rpx;
}
.time-chip {
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 28rpx;
  background: #F0F0F5;
  border: 2rpx solid #F0F0F5;
}
.time-chip text {
  font-size: 24rpx;
  color: #888888;
  font-weight: 600;
}
.time-chip.active {
  background: #4A90D9;
  border-color: #4A90D9;
}
.time-chip.active text {
  color: #FFFFFF;
}

/* Metrics Grid */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}
.metric-item {
  width: calc(50% - 16rpx);
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #F5F5FA;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.metric-item:nth-child(2n) {
  margin-right: 0;
}
.metric-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.metric-emoji {
  font-size: 28rpx;
}
.hr-bg { background: rgba(74,144,217,0.1); }
.spo2-bg { background: rgba(76,175,80,0.1); }
.steps-bg { background: rgba(255,167,38,0.1); }
.sleep-bg { background: rgba(92,107,192,0.1); }
.metric-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #1A1A2E;
}
.metric-unit {
  font-size: 22rpx;
  color: #999999;
  margin-left: 4rpx;
}
.metric-trend {
  font-size: 20rpx;
  font-weight: 600;
  margin-top: 6rpx;
  display: block;
}

/* BP Section */
.bp-section {
  padding: 0 24rpx;
  margin-top: 8rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 12rpx;
  display: block;
}
.bp-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  border: 1rpx solid #F5F5FA;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.bp-half {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.bp-number {
  font-size: 40rpx;
  font-weight: 800;
  color: #1A1A2E;
}
.bp-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}
.bp-status {
  font-size: 20rpx;
  font-weight: 600;
  margin-top: 6rpx;
}
.bp-divider {
  width: 1rpx;
  background: #F0F0F5;
  margin: 0 16rpx;
}

/* Steps Summary */
.steps-summary {
  display: flex;
  padding: 16rpx 20rpx;
}
.step-stat {
  flex: 1;
  margin-right: 12rpx;
  padding: 20rpx 12rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  align-items: center;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.step-stat:last-child {
  margin-right: 0;
}
.step-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
}
.step-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* Trend Chart */
.trend-section {
  padding: 0 24rpx;
  margin-top: 16rpx;
}
.trend-canvas {
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #F5F5FA;
}

/* AI Insight */
.ai-insight {
  margin: 16rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #EDE9FE, #DBEAFE);
  border-radius: 20rpx;
  display: flex;
  align-items: flex-start;
}
.ai-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #7C3AED;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ai-icon {
  font-size: 32rpx;
}
.ai-content {
  flex: 1;
  margin-left: 16rpx;
}
.ai-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #5B21B6;
}
.ai-text {
  font-size: 22rpx;
  color: #6D28D9;
  margin-top: 6rpx;
  line-height: 1.6;
}

/* Compare Section */
.compare-section {
  padding: 0 24rpx;
  margin-top: 16rpx;
}
.compare-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.compare-toggle {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: #F0F0F5;
}
.compare-toggle .on {
  color: #FFFFFF;
}
.compare-toggle .off {
  color: #888888;
}
.toggle-text {
  font-size: 22rpx;
  font-weight: 600;
}
.compare-list {
  margin-top: 12rpx;
}
.compare-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid #F0F0F0;
}
.compare-label {
  width: 100rpx;
  font-size: 24rpx;
  color: #666666;
}
.compare-bar-wrap {
  flex: 1;
  margin: 0 12rpx;
}
.compare-bar-bg {
  height: 12rpx;
  background: #F0F0F5;
  border-radius: 6rpx;
}
.compare-bar-fill {
  height: 12rpx;
  border-radius: 6rpx;
}
.compare-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #1A1A2E;
}
.compare-diff {
  font-size: 20rpx;
  font-weight: 700;
  margin-left: 8rpx;
  white-space: nowrap;
}

.bottom-spacer {
  height: 40rpx;
}
