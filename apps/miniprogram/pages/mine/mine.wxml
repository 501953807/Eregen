<view class="page">
  <view class="profile-card">
    <view class="avatar">{{avatar}}</view>
    <view class="name">{{userName}}</view>
    <view class="role">{{userRole}}</view>
  </view>
  <view class="menu-list">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="title"
          bindtap="handleMenuTap" data-index="{{index}}">
      <text>{{item.title}}</text>
      <text class="arrow">›</text>
    </view>
  </view>
  <!-- Settings section -->
  <view class="menu-list" style="margin-top: 24rpx;">
    <view class="menu-item">
      <text>推送通知</text>
      <switch checked="{{settings.pushEnabled}}" bindchange="onPushChange" color="#E8734A" />
    </view>
    <view class="menu-item">
      <text>声音提醒</text>
      <switch checked="{{settings.soundEnabled}}" bindchange="onSoundChange" color="#E8734A" />
    </view>
    <view class="menu-item">
      <text>震动提醒</text>
      <switch checked="{{settings.vibrationEnabled}}" bindchange="onVibrationChange" color="#E8734A" />
    </view>
    <view class="menu-item" bindtap="saveSettings">
      <text>保存设置</text>
      <text class="arrow">›</text>
    </view>
  </view>
  <view class="logout-btn" bindtap="onLogout">
    <text>退出登录</text>
  </view>
</view>
