page {
  background: #f5f6fa;
  min-height: 100vh;
  padding: 32rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 12rpx;
  display: block;
}

.scan-section {
  margin-bottom: 32rpx;
}

.scan-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.scan-icon {
  font-size: 36rpx;
}

.form-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #595959;
  margin-bottom: 12rpx;
  display: block;
}

.picker-value {
  font-size: 30rpx;
  color: #1a1a1a;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-input {
  font-size: 30rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.bind-btn {
  background: #1890ff;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-top: 24rpx;
}

.bind-btn.binding {
  background: #91d5ff;
}

.bound-section {
  margin-top: 16rpx;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bound-device {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.device-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.avatar-bracelet {
  background: #e6f7ff;
}

.avatar-pillbox {
  background: #fff7e6;
}

.device-details {
  flex: 1;
  min-width: 0;
}

.device-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.device-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-badge.online {
  background: #f6ffed;
  color: #52c41a;
}

.status-badge.offline {
  background: #f5f5f5;
  color: #8c8c8c;
}

.device-sn {
  font-size: 24rpx;
  color: #8c8c8c;
  display: block;
  margin-bottom: 4rpx;
}

.device-bound {
  font-size: 24rpx;
  color: #bfbfbf;
  display: block;
}

.device-actions-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.unbind-link {
  font-size: 26rpx;
  color: #ff4d4f;
}

/* Firmware version section */
.fw-section {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #f0f0f0;
}

.fw-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fw-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.fw-current {
  font-size: 24rpx;
  color: #595959;
  font-family: monospace;
}

.fw-update {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  gap: 12rpx;
}

.fw-new {
  font-size: 24rpx;
  color: #fa8c16;
  font-weight: 500;
}

.ota-btn {
  background: #ff4d4f;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  line-height: 1.4;
}

.fw-latest {
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 4rpx;
}

.checking-waiting {
  text-align: center;
  padding: 40rpx 0;
}

.checking-text {
  font-size: 26rpx;
  color: #8c8c8c;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8c8c8c;
  display: block;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #bfbfbf;
  display: block;
}
