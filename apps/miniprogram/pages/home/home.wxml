<!--pages/home/home.wxml-->
<view class="page">
  <!-- Header with gradient background -->
  <view class="page-header">
    <view class="header-top">
      <view class="brand">
        <text class="app-name">颐贞 Eregen</text>
        <text class="app-subtitle">守护家人健康</text>
      </view>
    </view>
    <view class="elder-selector-mini">
      <view wx:for="{{elderlyList}}" wx:key="id"
            class="elder-chip {{activeElderly === index ? 'active' : ''}}"
            data-index="{{index}}" bindtap="switchElderly">
        <view class="elder-chip-avatar">{{item.avatar}}</view>
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- Quick Stats Card -->
  <view class="quick-card">
    <view class="quick-card-title">
      <text>实时状态</text>
      <navigator url="/pages/health/index" class="quick-card-more">详情 →</navigator>
    </view>
    <view class="quick-stats">
      <view class="quick-stat good">
        <text class="quick-stat-icon">❤️</text>
        <text class="quick-stat-value">{{healthData.hr || '--'}}</text>
        <text class="quick-stat-label">心率 bpm</text>
      </view>
      <view class="quick-stat good">
        <text class="quick-stat-icon">🫁</text>
        <text class="quick-stat-value">{{healthData.spo2 || '--'}}%</text>
        <text class="quick-stat-label">血氧</text>
      </view>
      <view class="quick-stat warn">
        <text class="quick-stat-icon">🚶</text>
        <text class="quick-stat-value">{{_formatSteps(healthData.steps)}}</text>
        <text class="quick-stat-label">今日步数</text>
      </view>
      <view class="quick-stat">
        <text class="quick-stat-icon">🔋</text>
        <text class="quick-stat-value">{{healthData.battery || '--'}}%</text>
        <text class="quick-stat-label">设备电量</text>
      </view>
    </view>
  </view>

  <!-- SOS Banner -->
  <view class="sos-banner">
    <view class="sos-icon">⚡</view>
    <view class="sos-text">
      <text class="sos-title">紧急联系人一键呼叫</text>
      <text class="sos-desc">{{elderlyList[activeElderly]?.name || '长辈'}}设备异常时自动通知</text>
    </view>
    <button class="sos-btn" bindtap="goToSettings">设置</button>
  </view>

  <!-- Location Section -->
  <view class="location-section">
    <view class="location-card">
      <view class="location-map">
        <text class="map-pin">📍</text>
        <view class="map-label">{{location.address}}</view>
      </view>
      <view class="location-info">
        <view>
          <text class="location-text">当前位置正常，在安全区域内</text>
          <text class="location-time">{{location.updated}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Medication Reminder -->
  <view class="med-section">
    <view class="med-card">
      <view class="med-card-header">
        <text class="med-card-title">💊 今日用药</text>
        <view class="med-ring-wrap">
          <text class="med-ring-text">{{_medRatio()}}</text>
        </view>
      </view>
      <view class="med-list">
        <view wx:for="{{medications}}" wx:key="time" class="med-row">
          <text class="med-time-tag">{{item.time}}</text>
          <view class="med-name-wrap">
            <text class="med-name">{{item.name}}</text>
            <text class="med-dose">1粒</text>
          </view>
          <view class="med-check {{item.status === 'taken' ? 'done' : ''}}" bindtap="toggleMed" data-index="{{index}}">
            <text wx:if="{{item.status === 'taken'}}">✓</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Health Tip -->
  <view class="health-tip">
    <text class="tip-icon">💡</text>
    <text class="tip-text">
      <text class="tip-title">今日健康提示</text><text>\n</text>
      爷爷今日步数略低于目标（5000步），建议傍晚散步30分钟。
    </text>
  </view>

  <!-- Bottom Actions -->
  <view class="bottom-actions">
    <view class="action-btn" bindtap="goHealthReport">
      <text class="action-icon">📊</text>
      <text class="action-label">健康报告</text>
    </view>
    <view class="action-btn" bindtap="goConsult">
      <text class="action-icon">💬</text>
      <text class="action-label">在线问诊</text>
    </view>
    <view class="action-btn" bindtap="goMedShop">
      <text class="action-icon">💊</text>
      <text class="action-label">药品购买</text>
    </view>
    <view class="action-btn" bindtap="goDevice">
      <text class="action-icon">⚙️</text>
      <text class="action-label">设备管理</text>
    </view>
  </view>

  <view class="footer">
    颐贞 Eregen · 守护每一位长辈<br>
    <text style="opacity:0.6;">版本 {{version}}</text>
  </view>
</view>
