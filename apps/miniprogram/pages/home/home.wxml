<view class="page">
  <!-- Elder Selector -->
  <view class="elder-selector">
    <view wx:for="{{elderlyList}}" wx:key="id"
          class="elder-chip {{activeElderly === index ? 'active' : ''}}"
          data-index="{{index}}" bindtap="switchElderly">
      <view class="elder-avatar">{{item.avatar}}</view>
      <text>{{item.name}}</text>
      <view class="online-dot {{item.online ? 'on' : 'off'}}"></view>
    </view>
  </view>

  <!-- Quick Status -->
  <view class="quick-status">
    <view class="qs-header">
      <text class="qs-title">{{elderlyList[activeElderly].name}} · 健康状态</text>
      <text class="qs-time">更新于 2 分钟前</text>
    </view>
    <view class="qs-grid">
      <view class="qs-item">
        <text class="qs-icon">❤️</text>
        <text class="qs-val">{{healthData.hr}}</text>
        <text class="qs-lbl">心率 bpm</text>
      </view>
      <view class="qs-item">
        <text class="qs-icon">🫁</text>
        <text class="qs-val">{{healthData.spo2}}%</text>
        <text class="qs-lbl">血氧</text>
      </view>
      <view class="qs-item">
        <text class="qs-icon">🚶</text>
        <text class="qs-val">{{healthData.steps}}</text>
        <text class="qs-lbl">今日步数</text>
      </view>
      <view class="qs-item">
        <text class="qs-icon">🔋</text>
        <text class="qs-val">{{healthData.battery}}%</text>
        <text class="qs-lbl">电量</text>
      </view>
    </view>
  </view>

  <!-- Location Mini Card -->
  <view class="location-mini">
    <view class="location-map">
      <view class="map-pin"></view>
    </view>
    <view class="location-info">
      <view class="loc-text">
        <text>{{location.address}}</text>
        <text class="loc-sub">{{location.updated}}</text>
      </view>
      <navigator url="/pages/map/index" class="loc-link">查看地图 →</navigator>
    </view>
  </view>

  <!-- Quick Actions -->
  <view class="section-label">快捷操作</view>
  <view class="quick-actions">
    <view class="qa-item" style="background:#FEF2F2;">
      <text class="qa-icon">⚠️</text>
      <text class="qa-label">一键呼叫</text>
    </view>
    <view class="qa-item" style="background:#DBEAFE;">
      <text class="qa-icon">📞</text>
      <text class="qa-label">语音通话</text>
    </view>
    <view class="qa-item" style="background:#F0FDF4;">
      <text class="qa-icon">💊</text>
      <text class="qa-label">用药提醒</text>
    </view>
    <view class="qa-item" style="background:#FFFBEB;">
      <text class="qa-icon">📋</text>
      <text class="qa-label">历史记录</text>
    </view>
  </view>

  <!-- Medication -->
  <view class="section-label">
    今日用药
    <navigator url="/pages/medication/index" class="more">查看全部 →</navigator>
  </view>
  <view class="med-list">
    <view wx:for="{{medications}}" wx:key="time" class="med-item">
      <view class="med-check {{item.status === 'taken' ? 'done' : (item.status === 'pending' ? 'soon' : 'pending')}}">
        <text wx:if="{{item.status === 'taken'}}">✓</text>
        <text wx:elif="{{item.status === 'pending'}}">⏳</text>
        <text wx:else>○</text>
      </view>
      <view class="med-info">
        <text class="med-name">{{item.name}}</text>
        <text class="med-detail">{{item.time}} {{item.status === 'taken' ? '· 已服用 · ' + item.takenTime : (item.status === 'pending' ? '· 即将到时间' : '· 待服用')}}</text>
      </view>
      <text class="med-tag {{item.status === 'taken' ? 'done' : (item.status === 'pending' ? 'soon' : 'pending')}}">
        {{item.status === 'taken' ? '已服' : (item.status === 'pending' ? '待服' : '未服')}}
      </text>
    </view>
  </view>

  <!-- Recent Alerts -->
  <view class="section-label">
    最近告警
    <navigator url="/pages/alerts/index" class="more">全部 →</navigator>
  </view>
  <view class="alert-mini">
    <view wx:for="{{alerts}}" wx:key="type" class="alert-mini-item {{item.level}}">
      <view class="alert-mini-title">{{item.title}}</view>
      <view class="alert-mini-desc">{{item.desc}}</view>
      <view class="alert-mini-time">{{item.time}}</view>
    </view>
  </view>
</view>
