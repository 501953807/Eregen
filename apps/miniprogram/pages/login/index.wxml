<view class="page">
  <!-- Logo -->
  <view class="logo-section">
    <view class="logo-icon">颐</view>
    <text class="brand-name">Eregen 颐贞</text>
    <text class="brand-slogan">颐养正道，贞守安康</text>
  </view>

  <!-- Login Form -->
  <view class="form-section">
    <view class="form-title">手机号登录</view>

    <view class="input-group">
      <view class="input-label">手机号</view>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="input-group">
      <view class="input-label">验证码</view>
      <view class="code-row">
        <input
          class="input-field code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="send-btn {{countdown > 0 ? 'disabled' : ''}}"
          disabled="{{countdown > 0}}"
          bindtap="sendCode"
        >
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </button>
      </view>
    </view>

    <button
      class="login-btn {{loading ? 'loading' : ''}}"
      bindtap="login"
      disabled="{{loading}}"
    >
      <text wx:if="{{!loading}}">登 录</text>
      <text wx:else>登录中...</text>
    </button>

    <view class="agreement">
      <text>登录即表示同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
