/* pages/map/index.wxss */
.container {
  min-height: 100vh;
  background: #F7F8FC;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F5;
}
.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-text {
  font-size: 48rpx;
  color: #333;
  line-height: 1;
}
.header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.elderly-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
}
.location-time {
  font-size: 20rpx;
  color: #999999;
  margin-top: 2rpx;
}
.header-pin {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pin-icon {
  font-size: 32rpx;
}

.map-container {
  position: relative;
  height: calc(100vh - 100rpx);
}
.map-view {
  width: 100%;
  height: 100%;
}

.fence-overlay {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  max-width: 300rpx;
}
.geofence-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.fence-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1A1A2E;
}
.fence-count {
  font-size: 20rpx;
  color: #999999;
}
.fence-item {
  padding: 10rpx 0;
  border-top: 1rpx solid #F0F0F5;
}
.fence-name {
  font-size: 22rpx;
  color: #333;
}
.fence-radius {
  font-size: 18rpx;
  color: #999;
}
.fence-status {
  font-size: 18rpx;
  font-weight: 600;
  margin-top: 4rpx;
}
.fence-status.active { color: #4CAF50; }
.fence-status.inactive { color: #FF6B6B; }

/* Bottom Sheet */
.bottom-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 24rpx 40rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.08);
}
.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.sheet-location {
  display: flex;
  align-items: center;
}
.sheet-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
}
.online-dot {
  width: 16rpx;
  height: 16rpx;
  background: #4CAF50;
  border-radius: 50%;
  margin-left: 10rpx;
}
.sheet-online {
  font-size: 20rpx;
  color: #4CAF50;
  margin-left: 6rpx;
}
.sheet-actions {
  display: flex;
  gap: 20rpx;
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #F7F8FC;
  border-radius: 12rpx;
}
.action-icon {
  font-size: 32rpx;
}
.action-text {
  font-size: 18rpx;
  color: #666;
  margin-top: 2rpx;
}

.address-card {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F7F8FC;
  border-radius: 16rpx;
}
.address-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
}

.history-section {
  margin-top: 24rpx;
}
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.time-selector {
  display: flex;
}
.time-option {
  padding: 6rpx 16rpx;
  margin-left: 8rpx;
  border-radius: 12rpx;
  background: #F0F0F5;
}
.time-option text {
  font-size: 20rpx;
  color: #888;
}
.time-option.active {
  background: #4A90D9;
}
.time-option.active text {
  color: #FFF;
}
.history-chart {
  background: #FFFFFF;
  border: 1rpx solid #F5F5FA;
  border-radius: 16rpx;
  padding: 16rpx;
}
.chart-canvas {
  width: 100%;
  height: 200rpx;
}

.nearby-section {
  margin-top: 24rpx;
}
.nearby-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}
.nearby-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  margin-right: 16rpx;
  background: #F7F8FC;
  border-radius: 16rpx;
  width: 160rpx;
}
.place-icon {
  font-size: 40rpx;
}
.place-name {
  font-size: 22rpx;
  color: #333;
  margin-top: 6rpx;
  font-weight: 600;
}
.place-dist {
  font-size: 18rpx;
  color: #999;
  margin-top: 2rpx;
}

.center-button {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 20rpx;
  text-align: center;
}
.center-button::after {
  border: none;
}
