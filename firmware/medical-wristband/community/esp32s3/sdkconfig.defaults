# Eregen Community Wristband - ESP32-S3 SDK Config

## WiFi
CONFIG_ESP_WIFI_SSID="eregen-community"
CONFIG_ESP_WIFI_PASSWORD="eregen1234"

## MQTT (via wifi_mqtt_bridge)
CONFIG_MQTT_BROKER_URI="tcp://mqtt.eregen.local:1883"
CONFIG_MQTT_USERNAME="eregen"
CONFIG_MQTT_PASSWORD="eregen_password"

## BLE
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_BLE_ENABLED=y

## OLED (I2C GPIO)
CONFIG_OLED_SDA_GPIO=8
CONFIG_OLED_SCL_GPIO=9

## Logging
CONFIG_LOG_DEFAULT_LEVEL=INFO
CONFIG_LOG_MAXIMUM_LEVEL_INFO=y

## NVS
CONFIG_NVS_FLASH_PAGE_NUM=8
